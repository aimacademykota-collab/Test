{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(fonts|assets|images)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/index", "destination": "/" }
  ]
}
